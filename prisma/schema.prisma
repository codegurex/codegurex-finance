// Codegurex Finance — esquema inicial.
// Usuarios espejados desde auth.users de Supabase; resto del dominio aqui.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EMPLOYEE
  ACCOUNTANT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  STRIPE
  PAYPAL
  CRYPTO
  OTHER
}

enum SubscriptionFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clients       Client[]
  income        Income[]
  expenses      Expense[]
  projects      Project[]
  invoices      Invoice[]
  subscriptions Subscription[]

  @@map("users")
}

model Client {
  id        String       @id @default(cuid())
  name      String
  email     String?
  phone     String?
  company   String?
  country   String?
  status    ClientStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  ownerId String @map("owner_id") @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  income   Income[]
  projects Project[]
  invoices Invoice[]

  @@index([ownerId])
  @@map("clients")
}

model Income {
  id            String        @id @default(cuid())
  amount        Decimal       @db.Decimal(12, 2)
  category      String
  paymentMethod PaymentMethod @default(TRANSFER) @map("payment_method")
  date          DateTime      @default(now())
  notes         String?
  receiptUrl    String?       @map("receipt_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  ownerId   String   @map("owner_id") @db.Uuid
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  clientId  String?  @map("client_id")
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([date])
  @@map("income")
}

model Expense {
  id            String        @id @default(cuid())
  description   String
  amount        Decimal       @db.Decimal(12, 2)
  category      String
  paymentMethod PaymentMethod @default(TRANSFER) @map("payment_method")
  provider      String?
  date          DateTime      @default(now())
  receiptUrl    String?       @map("receipt_url")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  ownerId String @map("owner_id") @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([date])
  @@map("expenses")
}

model Project {
  id        String        @id @default(cuid())
  name      String
  service   String?
  price     Decimal       @db.Decimal(12, 2)
  status    ProjectStatus @default(PENDING)
  progress  Int           @default(0)
  startDate DateTime?     @map("start_date")
  endDate   DateTime?     @map("end_date")
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  ownerId  String @map("owner_id") @db.Uuid
  owner    User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  clientId String @map("client_id")
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  income   Income[]
  invoices Invoice[]

  @@index([ownerId])
  @@index([clientId])
  @@map("projects")
}

model Subscription {
  id           String                @id @default(cuid())
  name         String
  provider     String?
  amount       Decimal               @db.Decimal(12, 2)
  category     String
  frequency    SubscriptionFrequency @default(MONTHLY)
  nextRenewal  DateTime              @map("next_renewal")
  status       SubscriptionStatus    @default(ACTIVE)
  notes        String?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  ownerId String @map("owner_id") @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([nextRenewal])
  @@map("subscriptions")
}

model Invoice {
  id        String        @id @default(cuid())
  number    String        @unique
  amount    Decimal       @db.Decimal(12, 2)
  status    InvoiceStatus @default(PENDING)
  dueDate   DateTime      @map("due_date")
  issuedAt  DateTime      @default(now()) @map("issued_at")
  paidAt    DateTime?     @map("paid_at")
  notes     String?
  pdfUrl    String?       @map("pdf_url")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  ownerId   String   @map("owner_id") @db.Uuid
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  clientId  String   @map("client_id")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([status])
  @@map("invoices")
}
